---
/**
 * ArticleLayout.astro — Layout principal para todos los artículos de Dinari.
 *
 * Responsabilidades:
 *  - <head> completo: charset, viewport, title, meta description, canonical,
 *    Open Graph, robots, Google Fonts, CSS links
 *  - Schema.org JSON-LD dinámico (Article, FAQPage, HowTo, BreadcrumbList)
 *  - Slot de AdSense script (inactivo hasta activación)
 *  - Navbar y Footer globales de Dinari
 *  - Layout de dos columnas (artículo + sidebar) en desktop
 *  - main.js del sitio existente (navbar scroll + mobile menu)
 */

import type { CollectionEntry } from 'astro:content';
import Navbar       from '../components/Navbar.astro';
import Footer       from '../components/Footer.astro';
import ArticleHero  from '../components/ArticleHero.astro';
import Sidebar      from '../components/Sidebar.astro';
import AdSlot       from '../components/AdSlot.astro';

type Props = {
  frontmatter: CollectionEntry<'guias'>['data'];
  slug:        string;
};

const { frontmatter, slug } = Astro.props;
const {
  title,
  description,
  canonical,
  robots        = 'index, follow',
  ogTitle,
  ogDescription,
  ogType        = 'article',
  ogImage,
  heroTitle,
  heroSubtitle,
  heroBadge,
  heroColor     = 'sage',
  publishDate,
  updatedDate,
  author        = 'Dinari',
  breadcrumbs,
  schemaType    = 'Article',
  faqItems,
  howToSteps,
  sidebarCta,
  adSlots,
} = frontmatter;

// ── ADSENSE ────────────────────────────────────────────────────────────────
// Cuando tu publisher ID esté listo:
//  1. Reemplaza el string vacío con: 'ca-pub-XXXXXXXXXXXXXXXXX'
//  2. Cambia ADSENSE_ACTIVE a true en AdSlot.astro
const ADSENSE_PUBLISHER_ID = ''; // TODO: 'ca-pub-XXXXXXXXXXXXXXXXX'

// ── SCHEMA.ORG JSON-LD ─────────────────────────────────────────────────────
const schemaGraph: object[] = [];

// BreadcrumbList (siempre presente)
schemaGraph.push({
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, i) => ({
    '@type':    'ListItem',
    position:   i + 1,
    name:       crumb.name,
    item:       crumb.url,
  })),
});

// Article principal
const articleSchema: Record<string, unknown> = {
  '@type':       schemaType === 'Article+FAQ' ? 'Article' : schemaType === 'FAQPage' ? 'Article' : schemaType,
  headline:      heroTitle,
  description:   description,
  url:           canonical,
  author:        { '@type': 'Organization', name: author },
  publisher:     { '@type': 'Organization', name: 'Dinari', url: 'https://dinari.app' },
  datePublished: publishDate.toISOString().split('T')[0],
  inLanguage:    'es',
};
if (updatedDate) {
  articleSchema.dateModified = updatedDate.toISOString().split('T')[0];
}
if (ogImage) {
  articleSchema.image = ogImage;
}
schemaGraph.push(articleSchema);

// FAQPage (si hay faqItems)
if (faqItems && faqItems.length > 0 && (schemaType === 'FAQPage' || schemaType === 'Article+FAQ')) {
  schemaGraph.push({
    '@type': 'FAQPage',
    mainEntity: faqItems.map((faq) => ({
      '@type':        'Question',
      name:           faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
  });
}

// HowTo (si hay howToSteps)
if (howToSteps && howToSteps.length > 0 && schemaType === 'HowTo') {
  schemaGraph.push({
    '@type': 'HowTo',
    name:    heroTitle,
    step:    howToSteps.map((step, i) => ({
      '@type':    'HowToStep',
      position:   i + 1,
      name:       step.name,
      text:       step.text,
    })),
  });
}

const jsonLd = JSON.stringify({ '@context': 'https://schema.org', '@graph': schemaGraph });

const currentPath = `/${slug}/`;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO primario -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content={robots} />

  <!-- Open Graph -->
  <meta property="og:title"       content={ogTitle || title} />
  <meta property="og:description" content={ogDescription || description} />
  <meta property="og:type"        content={ogType} />
  <meta property="og:url"         content={canonical} />
  <meta property="og:locale"      content="es_MX" />
  <meta property="og:site_name"   content="Dinari" />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={ogTitle || title} />
  <meta name="twitter:description" content={ogDescription || description} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <!-- Google Fonts (mismo que el sitio actual) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Lora:ital,wght@0,600;1,400&display=swap"
    rel="stylesheet"
  />

  <!-- CSS del sitio Dinari (paths absolutos, funcionan en dev via Vite plugin) -->
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="stylesheet" href="/css/article.css" />

  <!-- Web App Manifest -->
  <link rel="manifest" href="/manifest.json" />

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={jsonLd} />

  <!-- AdSense script (inactivo — activar cuando publisher ID esté listo) -->
  {ADSENSE_PUBLISHER_ID && (
    <script
      async
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_PUBLISHER_ID}`}
      crossorigin="anonymous"
    ></script>
  )}
</head>

<body>

  <Navbar currentPath={currentPath} />

  <main id="main-content">

    <!-- Hero del artículo -->
    <ArticleHero
      badge={heroBadge}
      title={heroTitle}
      subtitle={heroSubtitle}
      color={heroColor}
      breadcrumbs={breadcrumbs}
    />

    <!-- Slot AdSense: tras el hero, antes del artículo -->
    {adSlots?.afterIntro && (
      <div class="container" style="padding-block: 0;">
        <AdSlot position="after-intro" slotId={adSlots.afterIntro} format="horizontal" />
      </div>
    )}

    <!-- Layout principal: artículo + sidebar -->
    <div class="container">
      <div class={`article-layout${sidebarCta ? ' article-layout--with-sidebar' : ''}`}>

        <!-- Artículo (contenido MDX) -->
        <article class="article-content" role="main">
          <slot />

          <!-- Slot AdSense: antes de la conclusión -->
          {adSlots?.beforeConclusion && (
            <AdSlot position="before-conclusion" slotId={adSlots.beforeConclusion} />
          )}
        </article>

        <!-- Sidebar CTA (desde frontmatter) -->
        {sidebarCta && (
          <Sidebar
            icon={sidebarCta.icon}
            title={sidebarCta.title}
            desc={sidebarCta.desc}
            links={sidebarCta.links}
            adSlotId={adSlots?.sidebar}
          />
        )}

      </div>
    </div>

  </main>

  <Footer />

  <!-- JS del sitio Dinari (navbar scroll + mobile menu) -->
  <script src="/js/main.js" defer></script>

</body>
</html>
