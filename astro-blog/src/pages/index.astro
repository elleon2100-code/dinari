---
/**
 * index.astro — Índice de todas las guías de Dinari.
 * Ruta: /guias/ (sirve como hub de artículos)
 *
 * Este archivo NO reemplaza a /como-salir-de-deudas/ que es el hub principal.
 * Sirve como entrada alternativa y como lista interna para el equipo.
 */
import { getCollection } from 'astro:content';

const articles = await getCollection('guias');
const sorted   = articles.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Guías de finanzas personales | Dinari</title>
  <meta name="description" content="Guías prácticas para salir de deudas, entender los métodos de pago y tomar control de tus finanzas personales. Sin jerga financiera." />
  <link rel="canonical" href="https://dinari.app/guias/" />
  <meta name="robots" content="index, follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Lora:ital,wght@0,600;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="manifest" href="/manifest.json" />
</head>
<body>

<!-- Navbar inline (sin componente para mantener independencia) -->
<header>
  <nav class="navbar" id="navbar" role="navigation" aria-label="Navegación principal">
    <div class="container">
      <div class="navbar__inner">
        <a href="/" class="navbar__logo" aria-label="Dinari - Inicio">
          <span class="navbar__logo-mark" aria-hidden="true">D</span>
          Dinari
        </a>
        <ul class="navbar__nav" role="list">
          <li><a href="/simulador-deudas/" class="navbar__link">Simulador</a></li>
          <li><a href="/calculadora-intereses/" class="navbar__link">Calculadora</a></li>
          <li><a href="/como-salir-de-deudas/" class="navbar__link" aria-current="page">Guías</a></li>
        </ul>
        <div class="navbar__cta">
          <a href="/simulador-deudas/" class="btn btn--sage btn--sm">Calcular mi deuda</a>
          <button class="navbar__toggle" id="nav-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>
    </div>
  </nav>
  <div class="mobile-menu" id="mobile-menu" role="dialog" aria-label="Menú móvil">
    <a href="/" class="mobile-menu__link">Inicio</a>
    <a href="/simulador-deudas/" class="mobile-menu__link">Simulador de Deudas</a>
    <a href="/calculadora-intereses/" class="mobile-menu__link">Calculadora de Intereses</a>
    <a href="/como-salir-de-deudas/" class="mobile-menu__link">Cómo salir de deudas</a>
  </div>
</header>

<main id="main-content" style="padding-block-start: calc(var(--navbar-h) + var(--sp-16)); padding-block-end: var(--sp-20);">
  <div class="container container--narrow">
    <h1 class="display-2" style="margin-bottom:var(--sp-4);">Guías de finanzas personales</h1>
    <p class="body-lg" style="margin-bottom:var(--sp-12);">
      Sin jerga. Sin motivación vacía. Solo el orden lógico que funciona para
      organizar y eliminar tus deudas.
    </p>

    <div style="display:flex; flex-direction:column; gap:var(--sp-6);">
      {sorted.map((article) => (
        <a
          href={`/${article.id}/`}
          class="card card--interactive"
          style="padding:var(--sp-6); display:block;"
          aria-label={`Leer: ${article.data.heroTitle}`}
        >
          <div style="display:flex; align-items:center; gap:var(--sp-3); margin-bottom:var(--sp-3);">
            <span class="badge badge--sage">{article.data.heroBadge}</span>
            {article.data.readTime && (
              <span class="body-sm">{article.data.readTime} min de lectura</span>
            )}
          </div>
          <h2 style="font-family:var(--font-serif); font-size:var(--text-2xl); margin-bottom:var(--sp-2);">
            {article.data.heroTitle}
          </h2>
          <p class="body-sm" style="margin-bottom:var(--sp-4);">
            {article.data.description}
          </p>
          <span style="color:var(--sage-600); font-weight:600; font-size:var(--text-sm);">
            Leer guía →
          </span>
        </a>
      ))}
    </div>
  </div>
</main>

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer__bottom" style="border-top:none; padding-top:0;">
      <p>&copy; {new Date().getFullYear()} Dinari. Todos los derechos reservados.</p>
      <p><a href="/" style="color:var(--stone-400);">Volver al inicio →</a></p>
    </div>
  </div>
</footer>

<script src="/js/main.js" defer></script>
</body>
</html>
